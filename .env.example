# ============================================================
# Environment Variables - Render + Neon Setup
# ============================================================
# Lokal: in eine .env Datei kopieren (NICHT committen).
# Render: im Dashboard unter Environment setzen.

# --- Required ---
NODE_ENV=production

# Neon PostgreSQL Connection String. Aus dem Neon-Dashboard kopieren.
# Wichtig: die URL mit "?sslmode=require" am Ende verwenden.
# Beispiel:
# postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Secret zum Signieren von JWT-Cookies. Generieren mit: openssl rand -hex 32
JWT_SECRET=

# --- Optional (nur wenn du diese Features nutzt) ---
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# PORT wird von Render automatisch gesetzt - nicht überschreiben.
